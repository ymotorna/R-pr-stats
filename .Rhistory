library(tidyverse)
library(boot)
transplant <- read_csv("https://raw.githubusercontent.com/Aranaur/aranaur.rbind.io/main/datasets/heart-transplant/heart-transplant.csv")
colnames(transplant)
sort(unique(transplant$acceptyear))
sort(unique(transplant$age))
transplant %>%
filter(!is.na(wait))
transplant %>%
filter(outcome == 'alive') %>%
group_by(transplant) %>%
summarize(n())
# add age_group to the table
transplant <- transplant %>%
mutate(age_group = cut(age, breaks=seq(0, 65, 5), include.lowest=T,
labels=c('0-5', '6-10', '11-15', '16-20', '21-25', '26-30', '31-35', '36-40', '41-45', '46-50', '51-55', '56-60', '61-65')))
# plot distribution by age group
theme_custom <- theme(
panel.grid.major.y = element_line(color = "darkgrey", size = 0.5),
panel.grid.minor.y = element_line(color = "darkgrey", size = 0.5, linetype = "dotted"),
legend.position='none')
transplant %>%
ggplot(aes(x=age_group, fill=age_group == '46-50')) +
geom_bar(, alpa=0.5) +
theme_minimal() +
labs(title='Patients Distribution by Age group',
x='Age group',
y='Number of patients') +
scale_fill_manual(values=c('#675a49', 'red')) +
theme_custom
# we can see that 46-50 age group is the most common. Let's find the percentage
# rate of it
transplant %>%
group_by(age_group) %>%
summarize(num = n(),
rate = round(num/nrow(.), 2))
# the group composes almost 27% of all the patients .
# we want to check the percentage that may occur within the patients for such experiments,
# or if 27% significantly differs from other samples' values
# h0: 27% of patients are 46-50 y.o.
# h1: patients of 46-50 y.o. are more/less common than 27%
# bootstrap
# for sample of age groups we create subsamples, then find a percentage of 46-50 y.o. patients
set.seed(123)
boot_data <- boot(data=transplant$age_group,
statistic= \(x, i) length(x[x[i] == '46-50']) /length(x),
R=10000)
# CI
boot_ci <- boot_data %>%
boot.ci(type='all', conf=.95)
invisible(cat(
'Expected rate:', boot_data$t0, '\n',
'Average difference with generated rates: -0.00038 \n',
'CI basic: ', boot_ci$basic[4:5], '\n',
'CI percentile: ', boot_ci$percent[4:5], '\n'))
# generated samples distribution
tibble(rate = round(boot_data$t, 2)) %>%
mutate(is_in_ci = rate < boot_ci$basic[4] | rate > boot_ci$basic[5]) %>%
ggplot(aes(x=rate, fill=is_in_ci)) +
geom_bar() +
geom_vline(xintercept = boot_data$t0, color='red', show.legend=T, linewidth=1) +
geom_text(aes(x=0.3, y=900, label='Expected rate'), color='red', vjust=-1) +
theme_minimal() +
labs(title='Generated samples distribution',
x='Rate of 46-50 y.o. patients',
y='Count') +
scale_fill_manual(values=c('#675a49', 'red')) +
theme_custom
# the expected rate is within CI, and the average deviation from it is very small,
# so there is no significant difference between the expected rate and the generated samples.
# on the graph we can see that the rates distribution is similar to normal with
# observed 27% rate in the center of it and far from the borders of CI.
# so, we do not reject h0.
# more than a foerth part of pacients were from 46-50 age group, having 11 groups
# in total, so further investigation can be done to find the reason for such a high rate.
